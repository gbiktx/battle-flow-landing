---
import { getCollection } from 'astro:content';
import { languages } from '../../../i18n/ui';
import { useTranslations } from '../../../i18n/utils';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import DownloadButtons from '../../../components/DownloadButtons.astro';
import Footer from '../../../components/Footer.astro';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const langKeys = Object.keys(languages);
const posts = await getCollection('blog', ({ id }) => {
  const [idLang] = id.split('/');
  const normalizedLang = langKeys.find(k => k.toLowerCase() === idLang.toLowerCase()) || idLang;
  return normalizedLang === lang;
});

const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={t('blog.title')}>
	<Nav />
	<main class="pt-32 pb-24">
		<div class="container mx-auto px-6">
			<header class="text-center mb-20">
				<h1 class="text-4xl md:text-6xl mb-6">{t('blog.title')}</h1>
				<p class="text-lg text-gray-400 max-w-2xl mx-auto">{t('blog.subtitle')}</p>
			</header>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{sortedPosts.map((post) => (
					<a href={`/${lang}/blog/${post.id.split('/')[1]}/`} class="glass rounded-2xl overflow-hidden hover:-translate-y-2 transition-transform card-shadow group">
						<div class="p-8">
							<div class="text-brand-blue text-[10px] font-black uppercase tracking-[0.2em] mb-4">
								{post.data.categories?.[0] || 'PvP Strategy'}
							</div>
							<h2 class="text-xl md:text-2xl mb-4 group-hover:text-brand-blue transition-colors line-clamp-2">
								{post.data.title}
							</h2>
							<p class="text-gray-400 text-sm leading-relaxed mb-6 line-clamp-3">
								{post.data.description}
							</p>
							<div class="flex items-center justify-between text-[10px] font-bold text-gray-500 uppercase tracking-widest">
								<span>{post.data.date.toLocaleDateString(lang)}</span>
								<span>{post.data.reading_time} MIN READ</span>
							</div>
						</div>
					</a>
				))}
			</div>
		</div>
	</main>
	<DownloadButtons />
	<Footer />
</Layout>
