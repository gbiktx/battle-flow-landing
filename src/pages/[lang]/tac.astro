---
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import { tacData } from '../../i18n/data';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { marked } from 'marked';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
const content = tacData[lang] || tacData.en;
const html = await marked.parse(content);
---

<Layout
	title={t('tac.title')}
	description={`${t('tac.title')} — BattleFlow Pokémon GO PvP companion app.`}
>
	<Nav />
	<main class="pt-32 pb-24">
		<div class="container mx-auto max-w-3xl px-6">
			<h1 class="text-4xl md:text-6xl mb-12">{t('tac.title')}</h1>
			<div class="prose prose-invert prose-brand lg:prose-xl max-w-none prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tighter prose-a:text-brand-blue prose-strong:text-white" set:html={html} />
		</div>
	</main>
	<Footer />
</Layout>
