---
import { languages } from '../../i18n/ui';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Intro from '../../components/Intro.astro';
import MainFeatures from '../../components/MainFeatures.astro';
import Showcase from '../../components/Showcase.astro';
import Stats from '../../components/Stats.astro';
import Features from '../../components/Features.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { buildFAQSchema, buildMobileAppSchemas } from '../../lib/seo-schemas';
import { getHomeFaqs } from '../../lib/faqs';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const jsonLd = [
  ...buildMobileAppSchemas({
    siteUrl: Astro.site!,
    lang,
    name: 'BattleFlow',
    description: t('hero.subtitle'),
  }),
  buildFAQSchema({ questions: getHomeFaqs(t) }),
];
---

<Layout jsonLd={jsonLd}>
	<Nav />
	<main>
		<Hero />
		<Intro />
		<MainFeatures />
		<Showcase />
		<Features />
		<FAQ />
		<CTA />
	</main>
	<Footer />
</Layout>
