---
import { whatsNewData } from '../i18n/data';
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
import { marked } from 'marked';

const lang = 'en' as const;
const t = useTranslations(lang);
const content = (whatsNewData.en ?? '').trim();
const html = content ? await marked.parse(content) : '';
---

<Layout title={t('whatsnew.title')} description={t('whatsnew.subtitle')} noindex={!content}>
	<main class="px-6 py-12 sm:py-16">
		<div class="container mx-auto max-w-2xl">
			<header class="mb-8">
				<h1 class="text-3xl sm:text-4xl font-black uppercase tracking-tighter">{t('whatsnew.title')}</h1>
				<p class="mt-2 text-white/60">{t('whatsnew.subtitle')}</p>
			</header>
			{content ? (
				<div
					class="prose prose-invert prose-brand max-w-none prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tighter prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-2 prose-h2:pt-8 prose-h2:border-t prose-h2:border-white/10 prose-em:not-italic prose-em:text-sm prose-em:uppercase prose-em:tracking-wide prose-em:text-white/40 prose-strong:text-white prose-a:text-brand-blue first:prose-h2:border-t-0 first:prose-h2:pt-0"
					set:html={html}
				/>
			) : (
				<p class="text-white/40 py-8">{t('whatsnew.empty')}</p>
			)}
		</div>
	</main>
</Layout>
