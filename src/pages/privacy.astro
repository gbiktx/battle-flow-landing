---
import { privacyData } from '../i18n/data';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n/utils';
import { marked } from 'marked';

const lang = 'en' as const;
const t = useTranslations(lang);
const content = privacyData.en;
const html = await marked.parse(content);
---

<Layout
	title={t('privacy.title')}
	description={`How BattleFlow handles your data. ${t('privacy.title')} for the BattleFlow Pokémon GO PvP companion app.`}
>
	<Nav />
	<main class="pt-32 pb-24">
		<div class="container mx-auto max-w-3xl px-6">
			<h1 class="text-4xl md:text-6xl mb-12">{t('privacy.title')}</h1>
			<div class="prose prose-invert prose-brand lg:prose-xl max-w-none prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tighter prose-a:text-brand-blue prose-strong:text-white" set:html={html} />
		</div>
	</main>
	<Footer />
</Layout>
