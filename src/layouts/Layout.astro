---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteTitle = title ? `${title} | BattleFlow` : `${t('site.title')}`;
const siteDescription = description || t('hero.subtitle');
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/png" href="/assets/images/current_logo_rounded.png" />
		<link rel="apple-touch-icon" href="/assets/images/current_logo_rounded.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO -->
		<title>{siteTitle}</title>
		<meta name="description" content={siteDescription} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="theme-color" content="#0D47A1" />

		<!-- Hreflang tags -->
		{Object.keys(languages).map((l) => {
			const segments = Astro.url.pathname.split('/').filter(Boolean);
			// Remove current language prefix if it exists
			if (Object.keys(languages).some(lang => lang.toLowerCase() === segments[0]?.toLowerCase())) {
				segments.shift();
			}
			
			const base = segments.join('/');
			const path = l === 'en'
				? `/${base}${base ? '/' : ''}`
				: `/${l}/${base}${base ? '/' : ''}`;
				
			return <link rel="alternate" hreflang={l} href={new URL(path, Astro.site)} />;
		})}
		<link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />

		<!-- Open Graph / Social -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={siteDescription} />
		<meta property="og:image" content={new URL('/assets/images/large-logo.png', Astro.site)} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={siteTitle} />
		<meta name="twitter:description" content={siteDescription} />
		<meta name="twitter:image" content={new URL('/assets/images/large-logo.png', Astro.site)} />
		<meta name="twitter:site" content="@battleflowapp" />
		<meta name="twitter:creator" content="@battleflowapp" />

		<!-- Structured Data -->
		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": "BattleFlow",
			"operatingSystem": "iOS, Android",
			"applicationCategory": "SportsApplication, GameApplication",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			},
			"aggregateRating": {
				"@type": "AggregateRating",
				"ratingValue": "4.9",
				"ratingCount": "100"
			},
			"description": siteDescription,
			"url": Astro.site,
			"image": new URL('/assets/images/large-logo.png', Astro.site).toString(),
			"author": {
				"@type": "Organization",
				"name": "Baru Software Co",
				"url": "https://baru.software"
			}
		})} />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@800;900&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen">
		<slot />
	</body>
</html>
