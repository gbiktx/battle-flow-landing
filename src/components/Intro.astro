---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-24 bg-brand-dark/50 border-y border-white/5">
  <div class="container mx-auto px-6 text-center max-w-4xl">
    <h2 class="text-4xl md:text-6xl mb-8 leading-tight">{t('intro.title')}</h2>
    <p class="text-xl md:text-2xl text-gray-400 leading-relaxed">
      {t('intro.desc')}
    </p>
  </div>
</section>
