---
import IvCalculator from './IvCalculator';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-24 relative overflow-hidden" id="iv-calculator">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl mb-4">{t('iv.title')}</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">{t('iv.subtitle')}</p>
      <div class="h-1.5 w-24 bg-linear-to-r from-brand-blue to-brand-accent mx-auto mt-6 rounded-full"></div>
    </div>

    <IvCalculator client:load lang={lang} />
  </div>
</section>
