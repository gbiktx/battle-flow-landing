---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqs = [
  { q: t('faq.q1'), a: t('faq.a1') },
  { q: t('faq.q2'), a: t('faq.a2') },
  { q: t('faq.q3'), a: t('faq.a3') },
  { q: t('faq.q4'), a: t('faq.a4') },
  { q: t('faq.q5'), a: t('faq.a5') },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": a,
    },
  })),
};
---

<section class="py-24 relative overflow-hidden bg-white/2">
  <div class="container mx-auto px-6 max-w-4xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl mb-4">{t('faq.title')}</h2>
      <div class="h-1.5 w-24 bg-linear-to-r from-brand-blue to-brand-accent mx-auto rounded-full"></div>
    </div>

    <div class="space-y-4">
      {faqs.map(({ q, a }) => (
        <details class="glass rounded-2xl card-shadow group">
          <summary class="flex items-center justify-between cursor-pointer p-6 md:p-8 text-lg md:text-xl font-bold list-none">
            {q}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0 ml-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 md:px-8 pb-6 md:pb-8 text-gray-400 leading-relaxed">
            {a}
          </div>
        </details>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
