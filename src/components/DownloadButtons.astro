---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-16 bg-white/5 border-y border-white/10">
  <div class="container mx-auto px-6 text-center">
    <h3 class="text-2xl md:text-3xl font-black text-white mb-8 tracking-tighter">
      {t('cta.title')}
    </h3>
    <div class="flex flex-col sm:flex-row items-center gap-6 justify-center">
      <a href="https://apps.apple.com/us/app/battleflow/id6738843812" target="_blank" class="w-full sm:w-auto px-10 py-5 rounded-2xl bg-white text-brand-dark font-black hover:scale-105 transition-all flex items-center justify-center gap-4 shadow-2xl">
        <img src="/assets/images/ios.svg" alt="App Store" class="h-8 w-auto invert" />
        {t('hero.cta_ios')}
      </a>
      <a href="https://play.google.com/store/apps/details?id=com.baru.software.oak" target="_blank" class="w-full sm:w-auto px-10 py-5 rounded-2xl bg-brand-blue/10 border border-brand-blue/30 text-white font-black hover:bg-brand-blue/20 transition-all flex items-center justify-center gap-4 shadow-xl">
        <img src="/assets/images/google-play-badge.png" alt="Google Play Store" class="h-8 w-auto object-contain" />
        {t('hero.cta_android')}
      </a>
    </div>
  </div>
</section>
