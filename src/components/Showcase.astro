---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Map i18n codes to directory names if they differ
const langToDir: Record<string, string> = {
  'zh-Hans': 'en', // Fallback to en if no zh-hans dir
};

const screenshotLang = langToDir[lang] || lang;
const screenshotsDir = `/assets/images/screenshots/${screenshotLang}`;

const screenshots = [
  { file: '1.png', alt: 'BattleFlow team generator screen showing optimized Pokémon GO PvP teams built from the user collection' },
  { file: '2.png', alt: 'BattleFlow team profile view rating threat control, coverage, recovery, and stability' },
  { file: '3.png', alt: 'BattleFlow matchup simulator showing a turn-by-turn Pokémon GO PvP battle timeline' },
  { file: '4.png', alt: 'BattleFlow IV checker displaying PvP rank 1 IV spreads and stat product for a Pokémon' },
  { file: '5.png', alt: 'BattleFlow local meta analysis chart of the most common leads and closers in Go Battle League' },
  { file: '6.png', alt: 'BattleFlow Pokémon box screen listing the trainer\u2019s best PvP candidates' },
];
---

<section class="py-24 bg-brand-dark/50 overflow-hidden">
  <div class="container mx-auto px-6 mb-12">
    <h2 class="text-3xl md:text-5xl text-center">{t('showcase.title')}</h2>
  </div>

  <div class="flex overflow-x-auto gap-6 px-6 pb-8 snap-x no-scrollbar">
    <div class="flex gap-6 mx-auto">
      {screenshots.map(s => (
        <div class="w-[280px] md:w-[320px] aspect-[9/19.5] flex-shrink-0 snap-center rounded-3xl overflow-hidden glass card-shadow">
          <img
            src={`${screenshotsDir}/${s.file}`}
            alt={s.alt}
            width="320"
            height="693"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
