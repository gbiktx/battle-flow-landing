---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

function getLocalizedPath(newLang: string) {
  const segments = currentPath.split('/').filter(Boolean);
  if (Object.keys(languages).some(lang => lang.toLowerCase() === segments[0]?.toLowerCase())) {
    segments.shift();
  }
  const base = segments.join('/');
  return newLang === 'en' 
    ? `/${base}${base ? '/' : ''}` 
    : `/${newLang}/${base}${base || newLang ? '/' : ''}`;
}
---

<nav class="fixed top-0 left-0 w-full z-50 glass border-b border-white/5 py-4 px-6">
  <div class="container mx-auto flex justify-between items-center">
    
    <a href={`/${lang === 'en' ? '' : lang + '/'}`} class="flex items-center gap-3 group">
      <img src="/assets/images/appicon.png" alt="" class="w-8 h-8 rounded-lg shadow-lg group-hover:scale-110 transition-transform" />
      <span class="text-xl font-black tracking-tighter">BATTLEFLOW</span>
    </a>

    <div class="flex items-center gap-8">
      <div class="hidden md:flex gap-8 text-xs font-bold uppercase tracking-widest text-gray-400">
        <a href={`/${lang === 'en' ? '' : lang + '/'}`} class="hover:text-white transition-colors">{t('nav.home')}</a>
        <a href={`/${lang === 'en' ? '' : lang + '/'}blog/`} class="hover:text-white transition-colors">{t('nav.blog')}</a>
      </div>

      <div class="relative group">
        <select 
          class="bg-white/5 border border-white/10 rounded-lg px-3 py-1 text-xs font-bold uppercase tracking-widest outline-none cursor-pointer hover:bg-white/10 transition-colors appearance-none pr-8"
          onchange="window.location.href = this.value"
        >
          {Object.entries(languages).map(([code, name]) => (
            <option value={getLocalizedPath(code)} selected={code === lang} class="bg-brand-dark">
              {name}
            </option>
          ))}
        </select>
        <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>

  </div>
</nav>
