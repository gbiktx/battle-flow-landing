---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-24 px-6 relative overflow-hidden">
  <div class="max-w-5xl mx-auto bg-linear-to-br from-brand-blue to-brand-dark rounded-3xl p-12 md:p-20 text-center relative card-shadow overflow-hidden group">
    <!-- Highlight Glow -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-brand-accent/20 blur-[80px] translate-x-1/2 -translate-y-1/2 group-hover:scale-150 transition-transform duration-700"></div>

    <h2 class="text-4xl md:text-6xl mb-6 relative z-10 leading-[0.9] italic uppercase">{t('cta.title')}</h2>
    <p class="text-lg md:text-xl text-white/80 mb-12 relative z-10 max-w-2xl mx-auto">{t('cta.subtitle')}</p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 relative z-10">
      <!-- App Store Button -->
      <a href="https://apps.apple.com/us/app/battleflow/id6738843812" target="_blank" class="w-full sm:w-[280px] h-[80px] bg-black border border-white/20 rounded-2xl flex items-center px-7 gap-5 hover:bg-white/5 hover:border-white/40 transition-all group shadow-2xl">
        <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center">
          <svg viewBox="0 0 384 512" class="w-9 h-9 fill-white transition-transform group-hover:scale-110">
            <path d="M318.7 268.7c-.2-36.7 21.3-64.4 50.4-81.2-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 21.8-88.5 21.8-11.4 0-51.1-20.8-83.6-20.8-42.3 0-81.8 24.4-103.2 61.9-43.2 75.2-11.1 186.1 31 247.1 20.6 29.8 44.8 63.3 76.9 62.2 31.3-1.1 43.1-20.1 81-20.1 37.9 0 48.9 20.1 81.1 19.4 33.1-.7 54.4-30.3 74.9-59.7 23.6-34.1 33.2-67.1 33.5-68.8-.7-.3-64.9-24.9-65.5-98.4zM286.1 102c15.7-19.1 26.2-45.5 23.3-71.9-22.1 1-48.8 14.8-64.6 32.5-14.2 15.8-26.7 42.9-23.3 68.7 24.4 1.9 48.9-10.2 64.6-29.3z"/>
          </svg>
        </div>
        <div class="flex flex-col items-start leading-none text-left">
          <span class="text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Download on</span>
          <span class="text-[22px] font-black text-white tracking-tight uppercase whitespace-nowrap">App Store</span>
        </div>
      </a>

      <!-- Google Play Button -->
      <a href="https://play.google.com/store/apps/details?id=com.baru.software.oak" target="_blank" class="w-full sm:w-[280px] h-[80px] bg-black border border-white/20 rounded-2xl flex items-center px-7 gap-5 hover:bg-white/5 hover:border-white/40 transition-all group shadow-2xl">
        <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center">
          <svg viewBox="0 0 512 512" class="w-9 h-9 transition-transform group-hover:scale-110">
            <path fill="#4285F4" d="M12 25c-3 4-5 10-5 18v426c0 8 2 14 5 18l1 1L240 256v-2l-227-230z"/> <!-- Left Blue -->
            <path fill="#FBBC05" d="M316 334l-76-78v-2l76-78 1 1 90 51c26 15 26 39 0 54l-90 51z"/> <!-- Right Yellow -->
            <path fill="#EA4335" d="M241 256l-229 231c4 3 10 4 17 0l308-175-96-56z"/> <!-- Bottom Red -->
            <path fill="#34A853" d="M241 256l96-56L30 25c-7-4-13-3-17 0l228 231z"/> <!-- Top Green -->
          </svg>
        </div>
        <div class="flex flex-col items-start leading-none text-left">
          <span class="text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Get it on</span>
          <span class="text-[22px] font-black text-white tracking-tight uppercase whitespace-nowrap">Google Play</span>
        </div>
      </a>
    </div>
  </div>
</section>
