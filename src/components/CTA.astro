---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-24 px-6 relative overflow-hidden">
  <div class="max-w-5xl mx-auto bg-linear-to-br from-brand-blue to-brand-dark rounded-3xl p-12 md:p-20 text-center relative card-shadow overflow-hidden group">
    <!-- Highlight Glow -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-brand-accent/20 blur-[80px] translate-x-1/2 -translate-y-1/2 group-hover:scale-150 transition-transform duration-700"></div>

    <h2 class="text-4xl md:text-6xl mb-6 relative z-10 leading-[0.9] italic">{t('cta.title')}</h2>
    <p class="text-lg md:text-xl text-brand-blue/80 mb-12 relative z-10 max-w-2xl mx-auto">{t('cta.subtitle')}</p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 relative z-10">
      <a href="https://apps.apple.com/us/app/battleflow/id6738843812" target="_blank" class="w-full sm:w-auto px-10 py-5 rounded-xl bg-white text-brand-dark font-black hover:scale-105 transition-transform flex items-center justify-center gap-4 shadow-2xl">
        <img src="/assets/images/ios.svg" alt="" class="h-8 w-auto invert" />
        {t('hero.cta_ios')}
      </a>
      <a href="https://play.google.com/store/apps/details?id=com.baru.software.oak" target="_blank" class="w-full sm:w-auto px-10 py-5 rounded-xl bg-brand-dark/30 border border-white/10 text-white font-black hover:bg-white/10 transition-colors flex items-center justify-center gap-4">
        <img src="/assets/images/google-play-badge.png" alt="" class="h-8 w-auto object-contain" />
        {t('hero.cta_android')}
      </a>
    </div>
  </div>
</section>
