---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Map i18n codes to directory names if they differ
const langToDir: Record<string, string> = {
  'zh-Hans': 'en', // Fallback to en if no zh-hans dir
};

const screenshotLang = langToDir[lang] || lang;
const screenshotsDir = `/assets/images/screenshots/${screenshotLang}`;

const mainFeatures = [
  {
    title: t('features.team_gen_title'),
    desc: t('features.team_gen_desc'),
    video: '/assets/images/Team-Generator-Preview.mp4',
    poster: `${screenshotsDir}/1.png`,
    reversed: false
  },
  {
    title: t('features.sim_title'),
    desc: t('features.sim_desc'),
    video: '/assets/images/Simulator-Preview.mp4',
    poster: `${screenshotsDir}/2.png`,
    reversed: true
  },
  {
    title: t('features.iv_title'),
    desc: t('features.iv_desc'),
    video: '/assets/images/IVChecker-Preview.mp4',
    poster: `${screenshotsDir}/3.png`,
    reversed: false
  }
];
---

<section class="py-24 bg-brand-dark/30">
  <div class="container mx-auto px-6">
    <div class="space-y-32">
      {mainFeatures.map((f) => (
        <div class={`flex flex-col ${f.reversed ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-12 md:gap-24`}>
          <!-- Text Content -->
          <div class="flex-1 text-center md:text-left">
            <h2 class="text-3xl md:text-5xl mb-6 leading-tight">{f.title}</h2>
            <p class="text-lg text-gray-400 leading-relaxed mb-8">
              {f.desc}
            </p>
            {f.title.includes('profile') && (
               <ul class="space-y-4 text-left inline-block md:block">
                {['Threat Control', 'Coverage', 'Recovery', 'Stability'].map(item => (
                  <li class="flex items-center gap-3 text-gray-300">
                    <span class="w-1.5 h-1.5 rounded-full bg-brand-blue"></span>
                    {item}
                  </li>
                ))}
              </ul>
            )}
          </div>

          <!-- Video Visual -->
          <div class="flex-1 w-full max-w-[320px] mx-auto">
            <div class="relative aspect-[9/19.5] rounded-[3rem] overflow-hidden glass card-shadow border-8 border-brand-dark/50">
              <video 
                src={f.video} 
                poster={f.poster}
                class="w-full h-full object-cover" 
                autoplay 
                muted 
                loop 
                playsinline
              ></video>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
